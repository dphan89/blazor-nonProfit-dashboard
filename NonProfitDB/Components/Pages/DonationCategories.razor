@page "/donationcategories"
@using NonProfitDB.Models
@using Microsoft.EntityFrameworkCore
@inject NonProfitDBContext _dbContext
@rendermode InteractiveServer
@inject Radzen.NotificationService NotificationService

<h3>Donation Categories</h3>

<style>
    .page-container {
        padding: 20px;
    }

    .rz-grid-table {
        width: 100%;
        table-layout: auto;
    }
</style>

<RadzenDataGrid @ref="_categoryGrid"
                Style="width:100%;"
                AllowAlternatingRows="false"
                AllowFiltering="true"
                AllowPaging="true"
                PageSize="5"
                AllowSorting="true"
                EditMode="@DataGridEditMode.Single"
                Data="@_categories"
                TItem="DonationCategory"
                RowUpdate="@OnUpdateRow"
                RowCreate="@OnCreateRow"
                ColumnWidth="150px">

    <!-- ***Add New Button*** -->
    <HeaderTemplate>
        <RadzenButton ButtonStyle="ButtonStyle.Success"
                      Icon="add_circle"
                      Text="Add New Category"
                      Click="@InsertRow"
                      Disabled="@(CategoriesToInsert.Count > 0)" />
    </HeaderTemplate>

    <Columns>

        <!-- ***Column: Category ID*** -->
        <RadzenDataGridColumn Property="DonationCategoryId"
                              Title="ID"
                              Width="120px"
                              Frozen="true" />

        <!-- ***Column: Category Name*** -->
        <RadzenDataGridColumn Property="CategoryName"
                              Title="Category Name"
                              Width="300px">
            <EditTemplate Context="category">
                <RadzenTextBox @bind-Value="category.CategoryName"
                               Style="width:250px; display:block"
                               Name="CategoryName" />
                <RadzenRequiredValidator Text="Category Name is required"
                                         Component="CategoryName"
                                         Popup="true" />
            </EditTemplate>
        </RadzenDataGridColumn>

        <!-- ***Column: Description*** -->
        <RadzenDataGridColumn Property="Description"
                              Title="Description"
                              Width="350px">
            <EditTemplate Context="category">
                <RadzenTextBox @bind-Value="category.Description"
                               Style="width:300px; display:block"
                               Name="Description" />
            </EditTemplate>
        </RadzenDataGridColumn>

        <!-- ***Column: Action Buttons*** -->
        <RadzenDataGridColumn Filterable="false"
                              Sortable="false"
                              TextAlign="TextAlign.Right"
                              Width="120px">

            <Template Context="category">
                <RadzenButton Icon="edit"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="@(() => EditRow(category))"
                              @onclick:stopPropagation="true" />

                <RadzenButton Icon="delete"
                              ButtonStyle="ButtonStyle.Danger"
                              Size="ButtonSize.Small"
                              class="rz-ms-1"
                              Click="@(() => DeleteRow(category))"
                              @onclick:stopPropagation="true" />
            </Template>

            <EditTemplate Context="category">
                <RadzenButton Icon="check"
                              ButtonStyle="ButtonStyle.Success"
                              Size="ButtonSize.Small"
                              Click="@(() => SaveRow(category))" />

                <RadzenButton Icon="close"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              class="rz-ms-1"
                              Click="@(() => CancelEdit(category))" />

                <RadzenButton Icon="delete"
                              ButtonStyle="ButtonStyle.Danger"
                              Size="ButtonSize.Small"
                              class="rz-ms-1"
                              Click="@(() => DeleteRow(category))" />
            </EditTemplate>

        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>





@code {
    RadzenDataGrid<DonationCategory> _categoryGrid;
    
    // List of the category row, cause it special
    List<DonationCategory> _categories = new();

    // UI row trackers
    List<DonationCategory> CategoriesToInsert = new(); //Track inserting rows
    List<DonationCategory> CategoriesToUpdate = new(); //Track edited rows

    // Load all category rows from the database when the page first starts
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _categories = await _dbContext.DonationCategories
                                      .AsNoTracking()
                                      .ToListAsync();
    }

    // Reset row copy pasta
    void Reset(DonationCategory category)
    {
        CategoriesToInsert.Remove(category);
        CategoriesToUpdate.Remove(category);
    }

    // Update row copy pasta
    async Task OnUpdateRow(DonationCategory category)
    {
        _dbContext.Update(category);
        await _dbContext.SaveChangesAsync();

        var index = _categories.FindIndex(c => c.DonationCategoryId == category.DonationCategoryId);
        if (index >= 0) _categories[index] = category;
    }

    // Create row copy paste
    async Task OnCreateRow(DonationCategory category)
    {
        _dbContext.Add(category);
        await _dbContext.SaveChangesAsync();

        _categories = await _dbContext.DonationCategories
                                      .AsNoTracking()
                                      .ToListAsync();

        CategoriesToInsert.Remove(category);
    }

    // Delete row copy pasta
    async Task OnDeleteRow(DonationCategory category)
    {
        _dbContext.Remove(category);
        await _dbContext.SaveChangesAsync();
        _categories.RemoveAll(c => c.DonationCategoryId == category.DonationCategoryId);
    }

    // Insert row copy pasta
    async Task InsertRow()
    {
        var cat = new DonationCategory();
        CategoriesToInsert.Add(cat);
        await _categoryGrid.InsertRow(cat);
    }

    // Edit row, but only allow existing categories to be edited
    async Task EditRow(DonationCategory category)
    {
        CategoriesToUpdate.Add(category);
        await _categoryGrid.EditRow(category);
    }

    // Delete row handler with validation and verification, blocks if it is being used
    async Task DeleteRow(DonationCategory category)
    {
        try
        {
            // Clear any tracking flags for this row
            Reset(category);

            // Check if this category is used by any donations
            bool inUse = await _dbContext.Donations
                .AsNoTracking()
                .AnyAsync(d => d.DonationCategoryId == category.DonationCategoryId);

            if (inUse)
            {
                // Just cancel edit and warn the user
                _categoryGrid.CancelEditRow(category);

                NotificationService?.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = "Delete blocked",
                    Detail = "This category is used by existing donations and cannot be deleted.",
                    Duration = 4000
                });

                return;
            }

            // Delete time baby
            var tracked = await _dbContext.DonationCategories.FindAsync(category.DonationCategoryId);
            if (tracked != null)
            {
                _dbContext.Remove(tracked);
            }
            else
            {
                var stub = new DonationCategory { DonationCategoryId = category.DonationCategoryId };
                _dbContext.Attach(stub);
                _dbContext.Remove(stub);
            }

            await _dbContext.SaveChangesAsync();

            // Remove from local list, refresh the grid, send sucess notification
            _categories.RemoveAll(c => c.DonationCategoryId == category.DonationCategoryId);
            await _categoryGrid.Reload();

            NotificationService?.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Deleted",
                Detail = "Category deleted successfully.",
                Duration = 2500
            });
        }

        // You failed!
        catch (Exception ex)
        {
            NotificationService?.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Delete failed",
                Detail = ex.Message,
                Duration = 4000
            });
        }
    }

    // Save method copy pasta
    async Task SaveRow(DonationCategory category)
    {
        await _categoryGrid.UpdateRow(category);

        // Simple success notification
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Success,
            Summary = "Saved",
            Detail = "Donor saved successfully",
            Duration = 2500
        });
    }

    // Cancel edit copy pasta
    void CancelEdit(DonationCategory category)
    {
        Reset(category);
        _categoryGrid.CancelEditRow(category);

        var entry = _dbContext.Entry(category);

        if (entry.State == EntityState.Modified)
        {
            entry.CurrentValues.SetValues(entry.OriginalValues);
            entry.State = EntityState.Unchanged;
        }
    }
}